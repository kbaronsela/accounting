# העתק ל-.env.local והתאם ערכים
# https://authjs.dev/getting-started/deployment#auth_secret
AUTH_SECRET=

# כתובת ציבורית של האפליקציה (לפרודקשן): כוללת פרוטוקול, למשל https://my-app.up.railway.app
# אם משאירים רק hostname ללא https:// הקוד מתקן בעת הרצה ל־https://..., אך עדיף להגדיר מלא מההתחלה.
AUTH_URL=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/accounting

# אופציונלי — OAuth (Google / Facebook)
# Google: ב־Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# הוסיפי Authorized redirect URIs (לפי הסביבה):
#   http://localhost:3000/api/auth/callback/google
#   https://<הדומיין-שלך>/api/auth/callback/google
# בבדיקה מטלפון על שרת פיתוח: גם http://<IP-המחשב>:3000/api/auth/callback/google
# והגדירי AUTH_URL באותה כתובת שהדפדפן פותח (לא localhost מהטלפון).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

BOOTSTRAP_ADMIN_EMAIL=
# מינימום 12 תווים — רק לסקריפט db:bootstrap-admin (מומלץ למחוק מהקובץ אחרי שימוש)
BOOTSTRAP_ADMIN_PASSWORD=

# אחסון מסמכים: מקומי (ברירת מחדל) או S3-compat (AWS S3 / Cloudflare R2 / MinIO וכד׳)
# ברירת מחדל: קבצים בעלאה נשמרים בתיקיה מקומית (מתאים לפיתוח).
# DOCUMENTS_STORAGE=local
#
# פרודקשן מומלץ:
# DOCUMENTS_STORAGE=s3
# DOCUMENTS_S3_BUCKET=your-bucket
# Cloudflare R2 / MinIO / S3 עם endpoint מותאם — חובה מפתחות (ב‑R2: R2 → Manage R2 API Tokens):
#   או AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY
#   או (אותו תוכן) DOCUMENTS_S3_ACCESS_KEY_ID + DOCUMENTS_S3_SECRET_ACCESS_KEY
# AWS S3 בלי endpoint מותאם — אפשר IAM/role בלי המפתחות האלה.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# DOCUMENTS_S3_ACCESS_KEY_ID=...
# DOCUMENTS_S3_SECRET_ACCESS_KEY=...
# DOCUMENTS_S3_REGION=eu-west-1
# Cloudflare R2 ודומיו — מאותה משפחת S3 דורשים endpoint:
# DOCUMENTS_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# אופציונלי: מאלץ path-style למיניו/חלק מהספקים (ברירת מחדל: כן כשיש endpoint מותאם)
# DOCUMENTS_S3_FORCE_PATH_STYLE=1
#
# פיתוח — אחסון קבצים מקומי בעלאת מסמכים.
# יחסית ל־cwd של Node (ברירת מחדל `.data/uploads`).
# בפריסות שבהן ה-cwd אינו תואם לתיקייה שבה נשמרו הקבצים — הגדירו נתיב **מוחלט** (Docker/standalone).
# LOCAL_UPLOAD_DIR=C:\data\uploads
#
# אם מסמכים ישנים נשארו בתיקיה אחרת מזו של ההגדרות הנוכחיות (גרסאות קודמות / העתק במחשב אחר):
# LOCAL_UPLOAD_LEGACY_DIR=C:\נתיב\ישן\uploads

# העלאות מסמכים — OCR מקומי (tesseract.js) אחרי complete-upload (ללא ענן)
# OCR_DISABLED=1 מדלג על OCR ומשאיר סטטוס uploaded (פיתוח מהיר / מכונות חלשות).
# OCR_DISABLED=

# בדיקת איכות תמונה לפני העלאה (צד דפדפן) — אופציונלי.
# בהירות: ממוצע אפור 0–255; מתחת לסף = "חשוך מדי". ברירת מחדל בקוד: 52 — סף גבוה יותר = יותר התראות על חשיכה.
# חדות (Laplacian variance): מתחת לסף = "לא חד". ברירת מחדל בקוד: 70 — סף גבוה יותר = יותר התראות על טשטוש.
# NEXT_PUBLIC_UPLOAD_IMAGE_DARK_MEAN_THRESHOLD=52
# NEXT_PUBLIC_UPLOAD_IMAGE_BLUR_VARIANCE_THRESHOLD=70
